{"ts":1782230389,"hash":"ad16ea9226b2198968af036174af168c44f4d5f1ec0b9f6a3af2d5a78d4e4db7","mode":"diff","ops":[{"tag":"replace","a1":2,"a2":3,"text":"import (\n\t\"bufio\"\n\t\"os\"\n\t\"strings\"\n)\n"},{"tag":"insert","a1":43,"a2":43,"text":"\tscanner := bufio.NewScanner(os.Stdin)\n\tscanner.Scan()\n\n\ttokens := strings.Fields(scanner.Text())\n\n\tvar st Stack\n\tvar out []string\n\n\tfor _, t := range tokens {\n\t\tif IsOp(t) {\n\t\t\tfor !st.Empty() && Prioridade(st.Top()) >= Prioridade(t) {\n\t\t\t\tout = append(out, st.Pop())\n\t\t\t}\n\t\t\tst.Push(t)\n\t\t} else {\n\t\t\tout = append(out, t)\n\t\t}\n\t}\n\n\tfor !st.Empty() {\n\t\tout = append(out, st.Pop())\n\t}\n"}]}
